# ============================================================
# LukeMontaje - Sistema de Control de Maquinaria Pesada
# ============================================================

# --- Supabase Self-Hosted ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-supabase-url.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# --- Gemini AI ---
GEMINI_API_KEY=tu_gemini_api_key_aqui
GEMINI_MODEL=gemini-2.5-flash

# --- Supabase Storage ---
# Bucket para evidencias fotográficas de faena
SUPABASE_STORAGE_BUCKET=evidencias-montaje

# --- WA-Bridge LukeMontaje (puerto 3025, separado del Delivery en 3015) ---
WA_BRIDGE_URL=http://localhost:3025
WA_BRIDGE_SECRET=tu_bridge_secret_aqui

# --- Seguridad API Admin ---
ADMIN_SECRET=tu_admin_secret_aqui
NEXT_PUBLIC_ADMIN_SECRET=tu_admin_secret_aqui

# --- URL pública del proyecto ---
NEXT_PUBLIC_BASE_URL=https://equipos.lukeapp.me
